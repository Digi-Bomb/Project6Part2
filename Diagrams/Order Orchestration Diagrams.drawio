  <diagram id="CrqdmcyTRD9afUOLLK4X" name="User Stories">
    <mxGraphModel dx="799" dy="716" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="6k1s9zylMI7cMjgRfyTS-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fontSize=10;" value="User Story:&amp;nbsp;&lt;div&gt;As a logged-in user, I want to view a list of all products so that I can know what is offered, and each product&#39;s price.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Acceptance Criteria:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Logged-in users can scroll through the products page of the website to see all products.&lt;/li&gt;&lt;li&gt;Logged-in users can see a product&#39;s price per 1 quantity.&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="410" x="10" y="10" as="geometry" />
        </mxCell>
        <mxCell id="NPmMuAlLBjBx7HNopc4W-14" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fontSize=10;" value="User Story:&amp;nbsp;&lt;div&gt;As a logged-in user, I want to know which items are out of stock so that I can know what I can&#39;t order.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Acceptance Criteria:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;The products that are out of stock are greyed out with the quantity as 0.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="410" x="430" y="10" as="geometry" />
        </mxCell>
        <mxCell id="NPmMuAlLBjBx7HNopc4W-16" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fontSize=10;" value="User Story:&amp;nbsp;&lt;div&gt;As a logged-in user, I want to add multiple products to my cart so that I can have them delivered to my house at the same time.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Acceptance Criteria:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Logged-in users can add products (with different but valid quantities) to their cart from the products page.&lt;/li&gt;&lt;li&gt;There is an information box that notifies the logged-in user that the product has been successfully added to their cart.&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="410" x="10" y="180" as="geometry" />
        </mxCell>
        <mxCell id="NPmMuAlLBjBx7HNopc4W-17" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;fontSize=10;" value="User Story:&amp;nbsp;&lt;div&gt;As a logged-in user, I want to view my cart and edit it so that I can verify my order before payment.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;Acceptance Criteria:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Logged-in users can view all items with their name, quantity, and price on the cart page.&lt;/li&gt;&lt;li&gt;Logged-in users can increase/decrease the quantity of an item if the stock for that item allows it.&lt;/li&gt;&lt;li&gt;Logged-in users can remove an item from their cart on the cart page.&lt;/li&gt;&lt;li&gt;Logged-in users can go back to the products/store page to add additional items to their cart.&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="410" x="430" y="180" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
